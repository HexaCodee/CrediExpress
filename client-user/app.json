{
  "expo": {
    "name": "CrediExpress",
    "slug": "client-user",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "crediexpress",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#08316D"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crediexpress.clientuser"
    },
    "android": {
      "package": "com.crediexpress.clientuser",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08316D"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
