# Copia este archivo a .env y ajusta las URLs si es necesario.
#
# Si pruebas en un dispositivo físico (no un emulador/simulador en esta misma
# computadora), "localhost" NO va a funcionar: usa la IP LAN de tu máquina,
# por ejemplo http://192.168.1.10:5062/api/v1/log

EXPO_PUBLIC_LOG_URL=http://localhost:5062/api/v1/log
EXPO_PUBLIC_AUTH_URL=http://localhost:5222/api/v1/auth
EXPO_PUBLIC_ACCOUNT_URL=http://localhost:3004/crediExpress/v1
EXPO_PUBLIC_BANK_URL=http://localhost:3006/crediExpress/v1/bank
EXPO_PUBLIC_ACCOUNT_TYPE_URL=http://localhost:3003/crediExpress/v1/account-types
EXPO_PUBLIC_CORE_BANKING_URL=http://localhost:3007/crediExpress/v1/core-banking
EXPO_PUBLIC_PRODUCT_CURRENCY_URL=http://localhost:3008/crediExpress/v1
EXPO_PUBLIC_CONVERSION_URL=http://localhost:3009/crediExpress/v1/conversions
