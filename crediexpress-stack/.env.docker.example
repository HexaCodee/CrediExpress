# Copia este archivo a .env.docker y completa los valores reales:
#   cp .env.docker.example .env.docker
#
# Levantar el stack (desde crediexpress-stack/):
#   docker compose --env-file .env.docker up --build

# --- BASE DE DATOS PG ---
POSTGRES_USER=IN6AM
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=crediexpress
POSTGRES_PORT=5436

# --- BASE DE DATOS MONGO ---
MONGO_USER=admin
MONGO_PASSWORD=change-me-mongo-password
MONGODB_PORT=27017

# --- PUERTOS EN USO DE SERVICIOS ---
AUTH_SERVICE_PORT=5222
LOG_SERVICE_PORT=5062
ROLE_NODE_PORT=3002
ACCOUNT_TYPE_SERVICE_PORT=3003
ACCOUNT_SERVICE_PORT=3004
BANK_SERVICE_PORT=3006
CORE_BANKING_SERVICE_PORT=3007
PRODUCT_CURRENCY_SERVICE_PORT=3008
CURRENCY_CONVERSION_SERVICE_PORT=3009
CLIENT_ADMIN_PORT=5173
CLIENT_USER_METRO_PORT=8081
CLIENT_USER_EXPO_PORT=19000
CLIENT_USER_EXPO_DEVTOOLS_PORT=19001
CLIENT_USER_EXPO_INSPECTOR_PORT=19002

# --- CONFIGURACIONES JWT (deben coincidir en todos los servicios) ---
JWT_SECRET=change-me-jwt-secret-min-256-bits
JWT_ISSUER=CrediExpress
JWT_AUDIENCE=CrediExpress
JWT_EXPIRATION_MINUTES=60
JWT_EXPIRES_IN=1h

# --- CONFIGURACIONES FRONTEND URLS (acceso desde el host) ---
FRONTEND_URL=http://localhost:5173
VITE_AUTH_URL=http://localhost:5062/api/v1
VITE_ADMIN_URL=http://localhost:5222/api/v1
VITE_ACCOUNT_TYPE_URL=http://localhost:3003/crediExpress/v1
VITE_BANK_URL=http://localhost:3006/crediExpress/v1
VITE_CORE_BANKING_URL=http://localhost:3007/crediExpress/v1
VITE_CURRENCY_CONVERSION_URL=http://localhost:3009/crediExpress/v1

# Expo: 10.0.2.2 = emulador Android; usa tu IP LAN para dispositivo fisico
EXPO_PUBLIC_AUTH_URL=http://10.0.2.2:5222/api/v1/auth
EXPO_PUBLIC_LOG_URL=http://10.0.2.2:5062/api/v1/log
EXPO_PUBLIC_ACCOUNT_URL=http://10.0.2.2:3004/crediExpress/v1
EXPO_PUBLIC_BANK_URL=http://10.0.2.2:3006/crediExpress/v1/bank
EXPO_PUBLIC_ACCOUNT_TYPE_URL=http://10.0.2.2:3003/crediExpress/v1/account-types
EXPO_PUBLIC_CORE_BANKING_URL=http://10.0.2.2:3007/crediExpress/v1/core-banking
EXPO_PUBLIC_PRODUCT_CURRENCY_URL=http://10.0.2.2:3008/crediExpress/v1
EXPO_PUBLIC_CONVERSION_URL=http://10.0.2.2:3009/crediExpress/v1/conversions
EXPO_PACKAGER_HOSTNAME=10.0.2.2

# --- URL INTERNA DEL SERVICIO DE CONVERSION (comunicacion entre contenedores) ---
CONVERSION_TIMEOUT_MS=8000

# --- EXCHANGE RATE API (currency-conversion-service) ---
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key
EXCHANGE_RATE_API_BASE_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_COMMISSION_PERCENT=1.5
RATES_CACHE_TTL_MINUTES=30
REQUEST_TIMEOUT_MS=8000

# --- CLOUDINARY (auth-service / log-service) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your-cloud-name/image/upload/
CLOUDINARY_FOLDER=auth_crediexpress/profiles
CLOUDINARY_DEFAULT_AVATAR_PATH=avatarDefault.png

# --- SMTP (auth-service y log-service) ---
SMTP_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_ENABLE_SSL=true
SMTP_USE_IMPLICIT_SSL=true
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@example.com
SMTP_FROM_NAME=CrediExpress Soporte
